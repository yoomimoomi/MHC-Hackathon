{
  "manifest_version": 3,
  "name": "Food Inspect",
  "version": "1.0.0",
  "description": "Chrome extension with a popup",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Food Inspect"
  },
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*",
        "https://maps.google.com/*"
      ],
      "css": ["content/maps-listings.css"],
      "js": ["content/maps-listings.js"],
      "run_at": "document_idle"
    }
  ]
}
